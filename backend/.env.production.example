# Project Filum — Production Backend Environment Variables
# =========================================================
# Usage (systemd / direct deployment):
#   cp .env.production.example .env
#   # Edit .env — fill in all REQUIRED values below
#   # Deploy to /srv/filum/backend/.env
#
# Both the backend service and the worker service MUST share
# the same .env file and the same STORAGE_BASE_PATH directory.
#
# Keep this file outside version control once populated.

# ── Required ──────────────────────────────────────────────────────────────────

APP_ENV=production

# PostgreSQL — use asyncpg driver
POSTGRES_DSN=postgresql+asyncpg://<user>:<password>@<host>:5432/<database>

# Redis
REDIS_DSN=redis://<host>:6379/0

# JWT secret key — MUST NOT be the default "change-me-in-production"
# Generate: python3 -c "import secrets; print(secrets.token_hex(48))"
JWT_SECRET_KEY=CHANGE_ME_at_least_64_hex_chars

# ── Storage ───────────────────────────────────────────────────────────────────
# Both backend and worker processes must have read/write access to this path.
STORAGE_PROVIDER=local
STORAGE_BUCKET=filum-prod
STORAGE_BASE_PATH=/srv/filum/data/storage

# ── AI integration (optional) ────────────────────────────────────────────────
# Omit or leave blank to disable AI features; the rest of the system continues
# to work normally without OpenAI credentials.
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSIONS=1536

# ── Browser Push / PWA (optional) ────────────────────────────────────────────
# Omit or leave blank to disable Web Push notifications.
# Generate a VAPID key pair: npx web-push generate-vapid-keys
# WEB_PUSH_PUBLIC_KEY=
# WEB_PUSH_PRIVATE_KEY=
# WEB_PUSH_SUBJECT=mailto:ops@example.com

# ── Optional tuning (defaults shown) ─────────────────────────────────────────
# JWT_ACCESS_TOKEN_MINUTES=30
# JWT_REFRESH_TOKEN_DAYS=7
# WORKERS=1
