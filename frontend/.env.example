VITE_API_BASE_URL=/api/v1
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8000
# Task center v2 UI (P2 views/stats). Set to false to use legacy board/gantt in TasksView.
# VITE_TASK_CENTER_V2_UI_ENABLED=true
# Optional fallback only. Standard flow fetches the Web Push public key
# from the backend after login via /api/v1/push-subscriptions/config.
# VITE_WEB_PUSH_PUBLIC_KEY=
