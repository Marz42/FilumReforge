# Project Filum — docker-compose.prod.yml environment variables
# Copy to .env.prod before starting:
#   cp .env.prod.example .env.prod
# Then edit .env.prod and fill in all required values.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=filum
POSTGRES_USER=filum
# Use a strong random password, e.g.:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 random bytes. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(48))"
JWT_SECRET_KEY=CHANGE_ME_at_least_64_hex_chars
CORS_ALLOWED_ORIGINS=https://app.example.com

# ── Gateway Nginx port ────────────────────────────────────────────────────────
HTTP_PORT=80

# ── Object storage ────────────────────────────────────────────────────────────
STORAGE_BUCKET=filum-prod

# ── AI integration (optional) ────────────────────────────────────────────────
# Leave blank to disable AI features gracefully.
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini

# ── Browser Push / PWA (optional) ────────────────────────────────────────────
# Generate VAPID key pair: npx web-push generate-vapid-keys
# WEB_PUSH_PUBLIC_KEY=
# WEB_PUSH_PRIVATE_KEY=
# WEB_PUSH_SUBJECT=mailto:ops@example.com
