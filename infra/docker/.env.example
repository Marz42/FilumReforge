POSTGRES_DB=filum
POSTGRES_USER=filum
POSTGRES_PASSWORD=filum
HTTP_PORT=8080
BACKEND_PORT=8000
FRONTEND_PORT=5173

# 邀请链接、部分回跳 URL 使用；默认与 docker-compose.yml 中一致（Nginx 统一入口 :8080）。
# 若只通过 Vite 直连 :5173 调试，可改为 http://127.0.0.1:5173
# FRONTEND_APP_URL=http://127.0.0.1:8080

# 与 backend/app/core/config.py 默认一致；演练关闭图引擎或任务中心 V2 时可改为 false
# WORKFLOW_GRAPH_ENGINE_ENABLED=true
# TASK_CENTER_V2_ENABLED=true
# WORKFLOW_WAIT_ANY_ENABLED=false
# WORKFLOW_DEEP_REJECTION_ENABLED=false

# Required: JWT secret for backend / worker startup.
# Must be at least 32 characters.
# Example: python -c "import secrets; print(secrets.token_hex(24))"
JWT_SECRET_KEY=

